# LifeOS Environment Variables
# Copy to /opt/openclaw.env and fill in real values.
# This file is checked into git as a template — NEVER put real secrets here.

# --- AI Model (swap provider by changing these 3 vars) ---
# xAI Grok (current):
AI_API_KEY=xai-your-key-here
AI_BASE_URL=https://api.x.ai/v1
AI_MODEL=grok-4-1-fast

# OpenAI GPT:
# AI_API_KEY=sk-your-key-here
# AI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o

# Anthropic Claude (via OpenAI-compatible proxy):
# AI_API_KEY=sk-ant-your-key-here
# AI_BASE_URL=https://api.anthropic.com/v1
# AI_MODEL=claude-sonnet-4-6

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-bot-token-here
CHAT_ID=your-chat-id-here

# --- Google (gog CLI) ---
GOG_ACCOUNT=your-email@gmail.com
GOG_KEYRING_PASSWORD=your-password-here

# --- Paths (optional, defaults shown) ---
# LIFEOS_DIR=/home/openclaw/lifeos
# GOG_PATH=/home/openclaw/.openclaw/workspace/homebrew/bin/gog
# SHEET_ID=your-sheet-id
# DRIVE_UPLOADS_FOLDER=your-folder-id

# --- Kept for Claude Code terminal sessions ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
XAI_API_KEY=xai-your-key-here
